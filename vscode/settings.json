{
      "security.workspace.trust.untrustedFiles": "open",
      "[cpp]": {
            "editor.defaultFormatter": "xaver.clang-format"
      },
      "[c]": {
            "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
      },
      "explorer.confirmDelete": false,
      "explorer.confirmDragAndDrop": false,
      "clangd.inactiveRegions.useBackgroundHighlight": true,
      "clangd.path": "/usr/bin/clangd",
      "clangd.arguments": [
            "--background-index",
            "--completion-style=bundled",
            "--pretty=false",
            "--clang-tidy",
            "--header-insertion=never",
            // "--compile-commands-dir=build"
      ],
      "clangd.fallbackFlags": [
            "-std=c++23"
      ],
      "files.associations": {
            ".cpp": "cpp",
            ".h": "cpp"
      },
      "editor.defaultFormatter": "xaver.clang-format",
      "clang-format.executable": "/opt/homebrew/bin/clang-format",
      "clang-format.assumeFilename": "",
      "clang-format.language.cpp.style": "file", // 或许可以移除
      "clang-format.style": "/Users/nhjk/MyClass/.clang-format",
      // "clang-format.language.cpp.style": "/Users/nhjk/MyClass/.clang-format",
      "[jsonc]": {
            "editor.defaultFormatter": "vscode.json-language-features"
      },
      "terminal.integrated.enableMultiLinePasteWarning": "never",
      // "editor.parameterHints.enabled": false,
      "editor.tabSize": 4,
      "editor.insertSpaces": true,
      "editor.formatOnSave": false,
      "editor.minimap.enabled": false,
      "editor.fontFamily": "'JetBrains Mono Nerd'",
      "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
      "editor.experimentalWhitespaceRendering": "font",
      "editor.inlayHints.maximumLength": 0,
      "editor.inlayHints.fontFamily": "'JetBrains Mono Nerd'",
      "[markdown]": {
            "editor.unicodeHighlight.ambiguousCharacters": false,
            "editor.unicodeHighlight.invisibleCharacters": false,
            "diffEditor.ignoreTrimWhitespace": false,
            "editor.wordWrap": "on",
            "editor.quickSuggestions": {
                  "comments": "off",
                  "strings": "off",
                  "other": "off"
            }
      },
      "cph.language.cpp.Command": "clang++",
      "cph.general.defaultLanguageTemplateFileLocation": "/run/media/nhjk/Data/TopCode/templateCode.cpp",
      "cph.language.c.Command": "clang",
      "cph.general.defaultLanguage": "cpp",
      "cph.general.showLiveUserCount": true,
      "cph.general.useShortCodeForcesName": true,
      "terminal.integrated.fontFamily": "'JetBrains Mono Nerd'",
      // "terminal.integrated.fontFamily": "monospace",
      "code-runner.saveFileBeforeRun": true,
      "code-runner.executorMap": {
            // "python": "\"/opt/homebrew/Caskroom/miniconda/base/envs/u12/bin/python\" -u",
            "octave": "/opt/homebrew/bin/octave"
      }
}
